# ─────────────────────────────────────────────
# OddJobTodd Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Always Required ─────────────────────────

# JWT signing secret (min 32 chars). Generate with: openssl rand -base64 48
JWT_SECRET=

# Previous JWT secret for key rotation (optional, set when rotating)
# JWT_SECRET_PREVIOUS=

# Admin email for login authorization
ADMIN_EMAIL=todd@oddjobtodd.info

# Admin password hash (salt:hash format). Generate with: npx tsx scripts/hash-password.ts <password>
ADMIN_PASSWORD_HASH=

# Anthropic API key for AI chat/extraction
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Client SDK (public, used by browser for legacy Firestore routes)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=odd-job-todd.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=odd-job-todd
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=odd-job-todd.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Optional: Database (falls back to PGlite) ─
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# ── Optional: Upstash Redis (falls back to in-memory rate limiting) ─
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# ── Optional: Twilio Verify (falls back to mock OTP, code=123456) ─
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OJT Phase 2: Phone-number identity adapter ─
# All OJT_ADMIN_* fields are required for loadAdminIdentity() to succeed.
# Regenerate-safe: changing the admin cert rotates the root of trust.

# 64-char hex sha256 — admin cert id (sha256("ojt:admin") is a reasonable seed)
OJT_ADMIN_CERT_ID=
# 66-char hex compressed secp256k1 public key
OJT_ADMIN_PUBKEY_HEX=
# 64-char hex secp256k1 private key — SECRET, server-only
OJT_ADMIN_PRIVKEY_HEX=
# Optional IPv6 BCA; derived from OJT_ADMIN_PUBKEY_HEX when absent
OJT_ADMIN_BCA=

# 32-byte hex master seed used to derive per-phone pubkeys.
# Rotating this invalidates every phone-derived identity in the store —
# treat it like the JWT secret (long-lived, never commit real value).
OJT_DERIVATION_SEED=

# JSON array of trusted REA peers: [{"phone":"+61..."}, ...]
# Each entry becomes a CertRecord in the known-cert store at boot.
OJT_REA_PEERS_JSON=[]

# ── Feature Flags ───────────────────────────
UPLOADS_ENABLED=false

# ── A5 CalendarGuard (default OFF — opt in per environment) ─
# When true, /api/v3/chat checks proposed times against the shared
# calendar_prod schedule before confirming, and atomically books
# happy-path proposals in the same drizzle transaction.
CALENDAR_GUARD_ENABLED=false

# Postgres URL for the shared calendar_prod database. In dev (and in
# tests) this can be omitted — the calendar client falls back to a
# dedicated PGlite instance under PGLITE_DATA_DIR_CALENDAR (or a
# per-test temp dir). On the VPS this MUST point at the operator's
# shared schedule DB so OJT/BRAP see the same bookings.
# CALENDAR_DATABASE_URL=postgres://user:pass@host:5432/calendar_prod

# Schedule object id (sem_objects row in calendar_prod). Defaults to
# 'schedule-primary' — match whatever was seeded by VPS-BOOTSTRAP.
# CAL_SCHEDULE_OBJECT_ID=schedule-primary

# PGlite data dir for the calendar fallback in dev. Defaults to
# './pglite-data-calendar'. Kept separate from the main pglite-data-v2
# because OJT's sem_objects schema diverges from the canonical one
# @semantos/calendar-ext expects.
# PGLITE_DATA_DIR_CALENDAR=./pglite-data-calendar

# Operator-only admin certId — required for /admin/calendar visibility.
# Falls back to OJT_ADMIN_CERT_ID when unset.
# OJT_OPERATOR_CERT_ID=
