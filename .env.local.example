# ─────────────────────────────────────────────
# OddJobTodd Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Always Required ─────────────────────────

# JWT signing secret (min 32 chars). Generate with: openssl rand -base64 48
JWT_SECRET=

# Previous JWT secret for key rotation (optional, set when rotating)
# JWT_SECRET_PREVIOUS=

# Admin email for login authorization
ADMIN_EMAIL=todd@oddjobtodd.info

# Anthropic API key for AI chat/extraction
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin SDK (export from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=odd-job-todd
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@odd-job-todd.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Client SDK (public, used by browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=odd-job-todd.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=odd-job-todd
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=odd-job-todd.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Optional: Database (falls back to PGlite) ─
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# ── Optional: Upstash Redis (falls back to in-memory rate limiting) ─
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# ── Optional: Twilio Verify (falls back to mock OTP, code=123456) ─
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Feature Flags ───────────────────────────
UPLOADS_ENABLED=false
